{
  "name": "neossh",
  "version": "1.0.0",
  "description": "A modern SSH/SFTP client built with Electron, Vue.js, and Node.js",
  "author": {
    "name": "NeoSSH Contributors",
    "email": "neossh@zemm.fr"
  },
  "homepage": "https://github.com/neossh/neossh",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:vite\" \"npm:electron:dev\"",
    "vite": "vite",
    "electron:dev": "cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux deb tar.gz",
    "build:mac": "vite build && electron-builder --mac",
    "build:all": "vite build && electron-builder -mwl",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.neossh.app",
    "productName": "NeoSSH",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["deb", "tar.gz"],
      "category": "Network",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "vue": "^3.4.0",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0"
  }
}